<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>12-Natsuki.PhinixRedPacket.Server</AssemblyName>
    <RootNamespace>Natsuki.PhinixRedPacketRework.Server</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../Shared/*.cs" />
    <Compile Include="*.cs" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Utils">
      <HintPath>$(PhinixUtils)</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UserManagement">
      <HintPath>$(PhinixUserManagement)</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
